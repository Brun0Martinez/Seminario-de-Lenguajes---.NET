using System;

namespace Teoria4;

public class Cuenta
{
    private int monto;
    private int titularDni;
    private string? titularNombre;

    public Cuenta()
    {
    }
    public Cuenta(string nombre, int dni)
    {
        this.titularNombre=nombre;
        this.titularDni=dni;
    }
    public Cuenta(string nombre)
    {
        this.titularNombre = nombre;
    }
    public Cuenta(int dni)
    {
        this.titularDni=dni;
    }

    public Cuenta(string nombre, int dni, int monto)
    {
        this.titularNombre=nombre;
        this.titularDni=dni;
        this.monto=monto;
    }
    public void Imprimir()
    {
        Console.WriteLine($"Nombre: {this.titularNombre}, DNI: {this.titularDni}, Monto: {this.monto}");
    }

    public void Depositar(int cant)
    {
        this.monto += cant;
    }

    public void Extraer(int cant)
    {
        if(this.monto > cant)
        {
            this.monto -= cant;
        }
        else
        {
            Console.WriteLine("Operacion cancelada,monto insuficiente");
        }
    }
}
