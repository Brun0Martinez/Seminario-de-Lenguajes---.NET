18) Escribir una función (método int Fac(int n)) que calcule el factorial de un número n pasado al
programa como parámetro por la línea de comando
a) Definiendo una función no recursiva
b) Definiendo una función recursiva
c) idem a b) pero con expression-bodied methods (Tip: utilizar el operador condicional ternario)

a)int numero = int.Parse(args[0]);

int Fac(int n)
{
    int multi = 1;

    for(int i = n; i > 0; i--)
    {
        multi = multi * i;
    }
    return multi;
}

Console.WriteLine(Fac(numero));
Console.Read();


b)int Fac(int n)
{
    if (n == 0)
    {
        return 1;
    }
    else
    {
        return n*Fac(n-1);
    }
}

int numero = int.Parse(args[0]);
Console.WriteLine(Fac(numero));
Console.Read();

c)int numero = int.Parse(args[0]);
int n = numero;
int Fac(int n) => (n == 0) ? 1 : n * Fac(n-1);
Console.WriteLine(Fac(n));
Console.Read();
